  // Lead Generation & Rewards
  // No auth required - guests can submit leads
  public shared ({ caller }) func submitLead(name : Text, phone : Text, email : Text, serviceInterest : Text, message : Text) : async Nat {
    if (name == "" or phone == "" or serviceInterest == "") {
      Runtime.trap("Name, phone, and service interest are required");
    };

    let id = nextLeadId;
    let lead : LeadSubmission = {
      id;
      name;
      phone;
      email;
      serviceInterest;
      message;
      createdAt = Time.now();
      rewardCredited = false;
    };
    leads.add(id, lead);
    nextLeadId += 1;

    // Credit reward only if user is logged in (not anonymous)
    if (AccessControl.hasPermission(accessControlState, caller, #user)) {
      let wallet = getWalletInternal(caller);
      let newWallet = {
        wallet with
        balance = wallet.balance + 2500;
        totalEarned = wallet.totalEarned + 2500;
      };
      wallets.add(caller, newWallet);
      let updatedLead = {
        lead with
        rewardCredited = true;
      };
      leads.add(id, updatedLead);
    };
    id;
  };

  public query ({ caller }) func getAllLeadSubmissions() : async [LeadSubmission] {
    checkAdmin(caller);
    leads.values().toArray().sort();
  };

  public shared ({ caller }) func markLeadRewarded(leadId : Nat) : async () {
    checkAdmin(caller);
    switch (leads.get(leadId)) {
      case (null) { Runtime.trap("Lead submission not found") };
      case (?lead) {
        let updatedLead = {
          lead with
          rewardCredited = true;
        };
        leads.add(leadId, updatedLead);
      };
    };
  };

  // Customer Reviews
  // No auth required - guests can submit reviews
  public shared ({ caller }) func submitReview(authorName : Text, rating : Nat, reviewText : Text) : async Nat {
    if (authorName == "") {
      Runtime.trap("Author name is required");
    };
    if (rating < 1 or rating > 5) {
      Runtime.trap("Rating must be between 1 and 5");
    };
    if (reviewText == "") {
      Runtime.trap("Review text is required");
    };
    let id = nextReviewId;
    let review : CustomerReview = {
      id;
      authorName;
      rating;
      reviewText;
      createdAt = Time.now();
      approved = false;
    };
    reviews.add(id, review);
    nextReviewId += 1;
    id;
  };

  // Public query - no auth required
  public query ({ caller }) func getApprovedReviews() : async [CustomerReview] {
    reviews.values().filter(
      func(review) { review.approved }
    ).toArray().sort();
  };

  public query ({ caller }) func getAllReviews() : async [CustomerReview] {
    checkAdmin(caller);
    reviews.values().toArray().sort();
  };

  public shared ({ caller }) func approveReview(reviewId : Nat) : async () {
    checkAdmin(caller);
    switch (reviews.get(reviewId)) {
      case (null) { Runtime.trap("Review not found") };
      case (?review) {
        let updatedReview = {
          review with
          approved = true;
        };
        reviews.add(reviewId, updatedReview);
      };
    };
  };

  // Customer Messages & Queries
  // No auth required - guests can submit messages
  public shared ({ caller }) func submitMessage(senderName : Text, phone : Text, email : Text, message : Text) : async Nat {
    if (senderName == "") {
      Runtime.trap("Sender name is required");
    };
    if (phone == "") {
      Runtime.trap("Phone number is required");
    };
    if (message == "") {
      Runtime.trap("Message text is required");
    };

    let id = nextMessageId;
    let msg : CustomerMessage = {
      id;
      senderName;
      phone;
      email;
      message;
      createdAt = Time.now();
      reply = null;
      repliedAt = null;
    };
    messages.add(id, msg);
    nextMessageId += 1;
    id;
  };

  public query ({ caller }) func getAllMessages() : async [CustomerMessage] {
    checkAdmin(caller);
    messages.values().toArray().sort();
  };

  public shared ({ caller }) func replyToMessage(messageId : Nat, replyText : Text) : async () {
    checkAdmin(caller);
    switch (messages.get(messageId)) {
      case (null) { Runtime.trap("Message not found") };
      case (?message) {
        let updatedMessage = {
          message with
          reply = ?replyText;
          repliedAt = ?Time.now();
        };
        messages.add(messageId, updatedMessage);
      };
    };
  };
};
